# Template de variáveis de ambiente da FASE_2.
# Copie este arquivo para ".env" (na pasta FASE_2/) e preencha os valores reais.
# O arquivo ".env" é ignorado pelo git e NUNCA deve ser commitado.

# Chave da API OpenAI (necessária para rodar a integração LLM em modo real,
# sem --force-local). Obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sua-chave-aqui

# (Opcional) Nível de log: DEBUG | INFO | WARNING | ERROR. Default: INFO
LOG_LEVEL=INFO
